server:
    http_listen_port: 9080
    grpc_listen_port: 0

positions:
    filename: /tmp/positions.yaml

clients:
    {% for host in groups['role_observability'] %}
    - url: http://{{ host }}:3100/loki/api/v1/push
    {% endfor %}

scrape_configs:
    - job_name: docker-logs
      static_configs:
        - targets:
            - localhost
          labels:
            job: docker-logs
            host: {{ inventory_hostname }}
            __path__: /var/lib/docker/containers/*/*log
    
      pipeline_stages:
        - json:
            expressions:
                stream: stream
                attrs: attrs
                tag: attrs.tag
                image_name: attrs.image_name
                container_name: attrs.container_name
        - labels:
            stream:
            tag:
            image_name:
            container_name: