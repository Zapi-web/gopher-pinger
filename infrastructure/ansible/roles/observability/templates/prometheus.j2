global:
    scrape_interval: {{ observability_scrape_interval | default(3) }}s

scrape_configs:
    - job_name: "apps"
      metrics_path: "/metrics"
      static_configs:
        - targets:
        {% for host in groups['role_app'] %}
          - "{{ host }}:80"
        {% endfor %}

    - job_name: "node_exporter_apps"
      static_configs:
        - targets:
        {% for host in groups['role_app'] %}
          - "{{ host }}:9100"
        {% endfor %}
    
    - job_name: "database"
      static_configs:
        - targets:
      {% for host in groups['role_database'] %}
          - "{{ host }}:9100"
      {% endfor %}